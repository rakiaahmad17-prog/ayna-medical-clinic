# ============================================
# AYNA CLINIC - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# IMPORTANT: Never commit .env.local to version control!

# ============================================
# CLINIC INFORMATION
# ============================================
NEXT_PUBLIC_WHATSAPP_NUMBER=6285343747010
NEXT_PUBLIC_WHATSAPP_NUMBER_2=6281256718190
NEXT_PUBLIC_CLINIC_NAME=Klinik AYNA Medical Clinic
NEXT_PUBLIC_CLINIC_EMAIL=Ayna.medclinic@gmail.com
NEXT_PUBLIC_INSTAGRAM=ayna_medicalclinic
NEXT_PUBLIC_CLINIC_ADDRESS=Jl. Pelita Raya, Bua Kana, Kec. Rappocini, Kota Makassar, Sulawesi Selatan 90231

# ============================================
# SUPABASE CONFIGURATION
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# DASHBOARD AUTHENTICATION
# ============================================
# Set a strong password for dashboard access
DASHBOARD_ADMIN_PASSWORD=change_this_password_in_production

# ============================================
# APPLICATION URL
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SECURITY KEYS
# ============================================
# Generate secrets with: openssl rand -base64 32
# IMPORTANT: Change these in production!
CSRF_SECRET=generate-a-secure-secret-here
SESSION_SECRET=generate-a-secure-session-here

# ============================================
# HOST CONFIGURATION
# ============================================
# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# OPTIONAL: FILE STORAGE
# ============================================
# STORAGE_BUCKET=blog-images
